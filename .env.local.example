# PA Chamber Endorsement Intelligence — Environment Variables
# Copy this file to .env.local and fill in your values

# PostgreSQL (Supabase recommended — free tier works)
# Get from: supabase.com → Project Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Redis Cache (Upstash recommended — free tier works)
# Get from: upstash.com → Create Database → REST URL
REDIS_URL=redis://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# Anthropic Claude API (for relevance scoring and claim extraction)
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# LegiScan API (for PA House members, votes, and bill sponsorships — free tier)
# Get from: legiscan.com/legiscan-api
LEGISCAN_API_KEY=YOUR_KEY_HERE

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
